rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────────
    // Derive department from role string (mirrors roleUtils.ts logic)
    function roleDepartment(role) {
      if (role == 'admin' || role == 'chairman') return 'all';
      if (role.startsWith('house_')) return 'house';
      if (role.startsWith('condo_')) return 'condo';
      if (role.startsWith('project_')) return 'project';
      return 'all';
    }

    function sameDepartmentAs(role, docDept) {
      return roleDepartment(role) == (docDept != null ? docDept : 'house');
    }

    // Tier 1: True cross-department Admins (see/manage everything)
    function isCrossDepartmentAdmin() {
      return request.auth.token.role == 'admin'
        || request.auth.token.role == 'chairman'
        || request.auth.token.role == 'house_admin_manager';
    }

    // Tier 2: Manager-level roles (own department only)
    // NOTE: condo_admin and house_admin are Manager-level despite name.
    function isManagerLevel() {
      return request.auth.token.role == 'project_manager'
        || request.auth.token.role == 'condo_manager'
        || request.auth.token.role == 'condo_admin'
        || request.auth.token.role == 'house_admin';
    }

    // ── Users collection ────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId
        || isCrossDepartmentAdmin()
      );
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Leads collection ──────────────────────────────────────────────
    match /leads/{leadId} {
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.ownerId;

      // Tier 1 (Admin) → everything
      // Tier 2 (Manager) → own department only
      // Tier 3 (Sale/Supervisor) → own records only
      allow read: if request.auth != null && (
        isCrossDepartmentAdmin()
        || (isManagerLevel() && sameDepartmentAs(request.auth.token.role, resource.data.department))
        || request.auth.uid == resource.data.ownerId
      );

      allow update, delete: if request.auth != null && (
        isCrossDepartmentAdmin()
        || (isManagerLevel() && sameDepartmentAs(request.auth.token.role, resource.data.department))
        || request.auth.uid == resource.data.ownerId
      );
    }

    // ── Check-ins collection ────────────────────────────────────────────
    match /checkins/{checkinId} {
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.ownerId;

      allow read: if request.auth != null && (
        isCrossDepartmentAdmin()
        || (isManagerLevel() && sameDepartmentAs(request.auth.token.role, resource.data.department))
        || request.auth.uid == resource.data.ownerId
      );

      allow update, delete: if request.auth != null && (
        isCrossDepartmentAdmin()
        || (isManagerLevel() && sameDepartmentAs(request.auth.token.role, resource.data.department))
        || request.auth.uid == resource.data.ownerId
      );
    }

    // ── Notifications collection ────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && isCrossDepartmentAdmin();
    }

    // ── Audio notes collection ──────────────────────────────────────────
    match /audio_notes/{noteId} {
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.ownerId;

      allow read: if request.auth != null && (
        isCrossDepartmentAdmin()
        || (isManagerLevel() && sameDepartmentAs(request.auth.token.role, resource.data.department))
        || request.auth.uid == resource.data.ownerId
      );

      allow update, delete: if request.auth != null && (
        isCrossDepartmentAdmin()
        || (isManagerLevel() && sameDepartmentAs(request.auth.token.role, resource.data.department))
        || request.auth.uid == resource.data.ownerId
      );
    }

    // ── Audit logs collection ───────────────────────────────────────────
    match /auditLogs/{logId} {
      allow read: if request.auth != null && (
        isCrossDepartmentAdmin()
        || isManagerLevel()
        || request.auth.token.role.matches('.*supervisor.*')
      );
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && isCrossDepartmentAdmin();
    }

    // ── Default deny ──────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
